#intent
# goal: "Sum prices of active products."
# pre: "data == Array[ProductStruct]"
# post: "return == Float64"
fn sum_active_prices(data:Array[ProductStruct])->Float64{
  data|filter(?.is_active==true)|sum(?.price)
}

verify{
  let items=[
    ProductStruct{id:"a",is_active:true,price:9.9},
    ProductStruct{id:"b",is_active:false,price:1.0},
    ProductStruct{id:"c",is_active:true,price:100.0}
  ]
  assert sum_active_prices(items) == 109.9
}

